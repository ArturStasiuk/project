╔══════════════════════════════════════════════════════════════════════════════╗
║                        DOKUMENTACJA – app.js                               ║
║  Plik: public/view/app.js                                                  ║
║  Język: JavaScript ES2022 (moduły ES, top-level await)                     ║
╚══════════════════════════════════════════════════════════════════════════════╝

Eksport domyślny: obiekt `view` (instancja WindowManager wzbogacona metodami
TaskbarManager i DesktopIconsManager). Po załadowaniu modułu dostępne są też:
  • view        – WindowManager + metody TaskbarManager + metody DesktopIconsManager
  • taskbar     – TaskbarManager (niezależna instancja, ta sama co użyta przez view)
  • desktopIcons – DesktopIconsManager (niezależna instancja)
  • contextMenu  – ContextMenuManager (niezależna instancja, eksport nazwany)

Stała MOBILE_BREAKPOINT = 768 px. Okna o szerokości ekranu ≤ 768 px są
automatycznie maksymalizowane i pozbawione przycisku maksymalizacji.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  class View
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Niskopoziomowy silnik UI pojedynczego okna. Każda instancja View obsługuje
  dokładnie jedno okno. WindowManager tworzy osobną instancję View dla każdego
  okna i zarządza nimi zbiorowo.

  Konstruktor
  ───────────
  new View({ taskbarId, containerId })
    taskbarId   – id elementu DOM paska zadań (atrybut id).
    containerId – id elementu DOM kontenera okien.

  Moduły (właściwości)
  ────────────────────
  view.taskbar  – moduł paska zadań (TaskbarModule)
  view.window   – moduł okna (WindowModule)
  view.titlebar – moduł paska tytułowego (TitlebarModule)
  view.menubar  – moduł menu górnego (MenubarModule)
  view.content  – moduł zawartości okna (ContentModule)

  ── TaskbarModule (view.taskbar) ────────────────────────────────────────────

  refresh({ showStart?, items? })                               → Promise<void>
    Czyści i przebudowuje cały pasek zadań.
    showStart  – czy wyświetlać przycisk Start (domyślnie: true).
    items      – tablica elementów paska.
    Zawsze rysuje prawy obszar (przycisk listy okien + zegar).

  addItem({ id, icon?, title, onClick, menuItems? })            → Promise<void>
    Dodaje element do paska lub aktualizuje istniejący (upsert).

  removeItem(id)                                                → Promise<void>
    Usuwa element o podanym id z paska.

  updateItem(id, { title?, icon?, onClick?, menuItems? })       → Promise<void>
    Aktualizuje tytuł, ikonę lub handler kliknięcia elementu paska.

  refreshStartMenu(items)                                       → Promise<void>
    Zastępuje całą zawartość menu Start nową listą pozycji.
    items – tablica [{ id?, icon?, label, disabled?, onClick }|'separator'].

  addStartMenuItem(item)                                        → Promise<void>
    Dołącza pozycję do menu Start lub aktualizuje istniejącą (upsert).

  removeStartMenuItem(id)                                       → Promise<void>
    Usuwa pozycję menu Start o podanym id.

  ── WindowModule (view.window) ──────────────────────────────────────────────

  create({ title?, icon?, statusText?, size?, controls? })      → Promise<void>
    Tworzy szkielet okna i dołącza go do kontenera.
    title      – tytuł wyświetlany na pasku tytułowym (domyślnie: '').
    icon       – emoji lub tekst ikony okna (domyślnie: null).
    statusText – tekst paska stanu (domyślnie: 'Gotowe').
    size       – 'auto' (domyślnie) lub { width, height } (px lub ciąg CSS).
    controls   – obiekt { minimize?, maximize?, close? } (wartości boolean).

  setTitle(title)                                               → Promise<void>
  setStatus(text)                                               → Promise<void>
  minimize()                                                    → Promise<void>
  maximize()                                                    → Promise<void>
  restore()                                                     → Promise<void>
  close()                                                       → Promise<void>

  ── TitlebarModule (view.titlebar) ──────────────────────────────────────────

  bindControls({ onMinimize?, onMaximize?, onClose? })          → Promise<void>
  addButton({ id?, label, onClick, position? })                 → Promise<void>
  removeButton(id)                                              → Promise<void>

  ── MenubarModule (view.menubar) ────────────────────────────────────────────

  refresh({ menus? })                                           → Promise<void>
  addMenu({ label, id, items?, position? })                     → Promise<void>
  removeMenu(id)                                                → Promise<void>
  addMenuItem(menuId, item)                                     → Promise<void>
  removeMenuItem(menuId, itemId)                                → Promise<void>

  ── ContentModule (view.content) ────────────────────────────────────────────

  refresh({ header?, subheader?, cards? })                      → Promise<void>
  setHeader(text)                                               → Promise<void>
  setSubheader(text)                                            → Promise<void>
  addCard({ id?, title?, text? })                               → Promise<void>
  removeCard(id)                                                → Promise<void>
  updateCard(id, { title?, text? })                             → Promise<void>

  ── Metody pomocnicze View ───────────────────────────────────────────────────

  isMinimized()                                                 → Promise<boolean>
  isMaximized()                                                 → Promise<boolean>
  _wmAction(action)                                             → Promise<void>
    Wewnętrzna logika: 'minimize' | 'maximize' | 'restore' | 'close'.
  _updateSize()                                                 → Promise<void>
    Przelicza rozmiar okna przy przywracaniu i zdarzeniu window resize.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  class WindowManager
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Zarządza wieloma oknami za pomocą unikalnego id. Każde okno to osobna
  instancja View. Metody przyjmują obiekt z polem `id`.

  Konstruktor
  ───────────
  new WindowManager({ containerId?, taskbarId? })
    containerId – id kontenera okien DOM (domyślnie: 'windowContainer').
    taskbarId   – id paska zadań DOM (domyślnie: 'taskbar').

  Tworzenie i zarządzanie oknami
  ──────────────────────────────
  addWindow({ id, title?, icon?, statusText?, size?, controls? })  → Promise<View|null>
    Tworzy nowe okno lub aktualizuje istniejące (upsert).
    Jeśli okno o danym id już istnieje – aktualizuje tytuł/status i je przywraca.
    Zwraca instancję View lub null gdy id jest puste.

    Przykład:
      await view.addWindow({ id: 'win-editor', title: 'Edytor', icon: '📝',
          statusText: 'Nowy dokument', size: { width: 800, height: 500 } });

  getWindow({ id })                                             → Promise<View|null>
    Zwraca instancję View dla danego id lub null.

    Przykład:
      const v = await view.getWindow({ id: 'win-editor' });
      await v.content.addCard({ id: 'extra', title: 'Info', text: 'Dane' });

  removeWindow({ id })                                          → Promise<void>
    Zamyka okno i usuwa je z mapy okien.

    Przykład:
      await view.removeWindow({ id: 'win-editor' });

  Stan okna
  ─────────
  setWindowTitle({ id, title })                                 → Promise<void>
    Przykład:
      await view.setWindowTitle({ id: 'win-editor', title: 'Edytor – plik.txt' });

  setWindowStatus({ id, text })                                 → Promise<void>
    Przykład:
      await view.setWindowStatus({ id: 'win-editor', text: 'Zapisano pomyślnie' });

  minimizeWindow({ id })                                        → Promise<void>
    Przykład:
      await view.minimizeWindow({ id: 'win-editor' });

  maximizeWindow({ id })                                        → Promise<void>
    Przykład:
      await view.maximizeWindow({ id: 'win-editor' });

  restoreWindow({ id })                                         → Promise<void>
    Przykład:
      await view.restoreWindow({ id: 'win-editor' });

  isWindowMinimized({ id })                                     → Promise<boolean|null>
    Przykład:
      if (await view.isWindowMinimized({ id: 'win-editor' }))
          await view.restoreWindow({ id: 'win-editor' });

  isWindowMaximized({ id })                                     → Promise<boolean|null>
    Przykład:
      console.log(await view.isWindowMaximized({ id: 'win-editor' }));

  Pasek tytułowy
  ──────────────
  bindWindowControls({ id, onMinimize?, onMaximize?, onClose? }) → Promise<void>
    Nadpisuje handlery przycisków min/max/close.

    Przykład:
      await view.bindWindowControls({ id: 'win-editor',
          onClose: async () => {
              if (confirm('Zamknąć?')) await view.removeWindow({ id: 'win-editor' });
          }
      });

  addWindowButton({ id, btnId?, label, onClick, position? })    → Promise<void>
    Przykład:
      await view.addWindowButton({ id: 'win-editor', btnId: 'btn-save',
          label: '💾', onClick: () => alert('Zapisano!') });

  removeWindowButton({ id, btnId })                             → Promise<void>
    Przykład:
      await view.removeWindowButton({ id: 'win-editor', btnId: 'btn-save' });

  Zawartość okna
  ──────────────
  refreshWindowContent({ id, header?, subheader?, cards? })     → Promise<void>
    Przykład:
      await view.refreshWindowContent({ id: 'win-editor',
          header: 'Edytor tekstu', subheader: 'Wersja 1.0',
          cards: [{ id: 'c1', title: 'Dokument', text: 'Treść.' }] });

  setWindowHeader({ id, text })                                 → Promise<void>
    Przykład:
      await view.setWindowHeader({ id: 'win-editor', text: 'Mój dokument' });

  setWindowSubheader({ id, text })                              → Promise<void>
    Przykład:
      await view.setWindowSubheader({ id: 'win-editor', text: 'Ostatnio: 12:00' });

  addWindowCard({ id, cardId?, title?, text? })                 → Promise<void>
    Dodaje kartę lub aktualizuje istniejącą (upsert).

    Przykład:
      await view.addWindowCard({ id: 'win-editor', cardId: 'c1',
          title: 'Sekcja 1', text: '<p>Treść sekcji.</p>' });

  removeWindowCard({ id, cardId })                              → Promise<void>
    Przykład:
      await view.removeWindowCard({ id: 'win-editor', cardId: 'c1' });

  updateWindowCard({ id, cardId, title?, text? })               → Promise<void>
    Przykład:
      await view.updateWindowCard({ id: 'win-editor', cardId: 'c1',
          text: 'Zaktualizowana treść.' });

  Menu górne okna
  ───────────────
  refreshWindowMenubar({ id, menus })                           → Promise<void>
    Przykład:
      await view.refreshWindowMenubar({ id: 'win-editor', menus: [
          { label: 'Plik', id: 'menu-file', items: [
              { icon: '📄', label: 'Nowy',    onClick: () => {} },
              { icon: '💾', label: 'Zapisz',  onClick: () =>
                  view.setWindowStatus({ id: 'win-editor', text: 'Zapisano' }) }
          ]}
      ]});

  addWindowMenu({ id, menuId, label, items?, position? })       → Promise<void>
    Dodaje menu lub aktualizuje istniejące (upsert).

    Przykład:
      await view.addWindowMenu({ id: 'win-editor', menuId: 'menu-tools',
          label: 'Narzędzia',
          items: [{ icon: '⚙️', label: 'Ustawienia', onClick: () => {} }] });

  removeWindowMenu({ id, menuId })                              → Promise<void>
    Przykład:
      await view.removeWindowMenu({ id: 'win-editor', menuId: 'menu-tools' });

  addWindowMenuItem({ id, menuId, item })                       → Promise<void>
    Dodaje pozycję do menu lub aktualizuje istniejącą (upsert).

    Przykład:
      await view.addWindowMenuItem({ id: 'win-editor', menuId: 'menu-file',
          item: { icon: '📤', label: 'Eksportuj', onClick: () => alert('Eksport!') } });

  removeWindowMenuItem({ id, menuId, itemId })                  → Promise<void>
    Przykład:
      await view.removeWindowMenuItem({ id: 'win-editor', menuId: 'menu-file',
          itemId: 'mi-export' });

  addMeniuWindow({ id, menuId, label, items?, position? })      → Promise<void>
    Dodaje całe nowe menu do okna.

    Przykład:
      await view.addMeniuWindow({ id: 'win-editor', menuId: 'menu-tools',
          label: 'Narzędzia',
          items: [{ icon: '⚙️', label: 'Ustawienia', onClick: () => {} }] });

  refreshMeniuWindow({ id, menuId, label?, items })             → Promise<void>
    Odświeża (zastępuje) istniejące menu po menuId. Zachowuje dotychczasową
    etykietę, jeśli nie podano label.

    Przykład:
      await view.refreshMeniuWindow({ id: 'win-editor', menuId: 'menu-tools',
          items: [{ icon: '🔧', label: 'Nowe opcje', onClick: () => {} }] });

  deleteMeniuWindow({ id, menuId })                             → Promise<void>
    Usuwa menu z okna po menuId.

    Przykład:
      await view.deleteMeniuWindow({ id: 'win-editor', menuId: 'menu-tools' });

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  class TaskbarManager
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Zarządza paskiem zadań: pozycją, widocznością, auto-ukrywaniem oraz
  zawartością (elementy, menu Start).

  Konstruktor
  ───────────
  new TaskbarManager({ taskbarId?, containerId? })
    taskbarId   – id elementu DOM paska zadań (domyślnie: 'taskbar').
    containerId – id kontenera okien DOM (domyślnie: 'windowContainer').

  Zarządzanie zawartością
  ───────────────────────
  refreshTaskbar(cfg)                                           → Promise<void>
    Pełne odświeżenie paska. cfg – patrz View.taskbar.refresh().

    Przykład:
      await taskbar.refreshTaskbar({ showStart: true, items: [
          { id: 'tb-editor', icon: '📝', title: 'Edytor',
            onClick: () => view.restoreWindow({ id: 'win-editor' }) }
      ]});

  addTaskbarItem({ id, icon?, title, onClick, menuItems? })     → Promise<void>
    Dodaje element do paska lub aktualizuje istniejący (upsert).

    Przykład:
      await taskbar.addTaskbarItem({
          id: 'tb-editor', icon: '📝', title: 'Edytor',
          onClick: () => view.restoreWindow({ id: 'win-editor' }),
          menuItems: [
              { label: 'Przywróć',    onClick: () => view.restoreWindow({ id: 'win-editor' }) },
              { label: 'Minimalizuj', onClick: () => view.minimizeWindow({ id: 'win-editor' }) },
              'separator',
              { label: 'Zamknij', onClick: () => {
                  view.removeWindow({ id: 'win-editor' });
                  taskbar.removeTaskbarItem({ id: 'tb-editor' });
              }}
          ]
      });

  removeTaskbarItem({ id })                                     → Promise<void>
    Przykład:
      await taskbar.removeTaskbarItem({ id: 'tb-editor' });

  updateTaskbarItem({ id, title?, icon?, onClick?, menuItems? }) → Promise<void>
    Przykład:
      await taskbar.updateTaskbarItem({ id: 'tb-editor', title: 'Edytor *' });

  refreshStartMenu({ items })                                   → Promise<void>
    Zastępuje całą zawartość menu Start.

    Przykład:
      await taskbar.refreshStartMenu({ items: [
          { id: 'sm-editor', icon: '📝', label: 'Edytor',
            onClick: () => view.restoreWindow({ id: 'win-editor' }) },
          'separator',
          { id: 'sm-off', icon: '⏻', label: 'Wyłącz', disabled: true }
      ]});

  addStartMenuItem(item)                                        → Promise<void>
    Dodaje pozycję do menu Start lub aktualizuje istniejącą (upsert).

    Przykład:
      await taskbar.addStartMenuItem({ id: 'sm-browser', icon: '🌐',
          label: 'Przeglądarka', onClick: () => alert('Przeglądarka') });
      await taskbar.addStartMenuItem('separator');

  removeStartMenuItem({ id })                                   → Promise<void>
    Przykład:
      await taskbar.removeStartMenuItem({ id: 'sm-browser' });

  Pozycja paska zadań
  ───────────────────
  setTaskbarPosition(position)                                  → Promise<void>
    Ustawia pozycję paska: 'bottom' | 'top' | 'left' | 'right'.
    Aktualizuje CSS-owe zmienne --tb-top/bottom/left/right i przelicza
    rozmiar wszystkich zmaksymalizowanych okien.

    Przykład:
      await taskbar.setTaskbarPosition('top');
      await taskbar.setTaskbarPosition('left');
      await taskbar.setTaskbarPosition('bottom');

  Automatyczne ukrywanie
  ──────────────────────
  setTaskbarAutoHide(enabled)                                   → Promise<void>
    Włącza (true) lub wyłącza (false) automatyczne ukrywanie paska.
    Gdy włączone: pasek chowa się; okna zajmują cały ekran. Po najechaniu
    myszą lub dotknięciu pasek wysuwa się, a okna zmniejszają się.

    Przykład:
      await taskbar.setTaskbarAutoHide(true);
      await taskbar.setTaskbarAutoHide(false);

  toggleTaskbarAutoHide()                                       → Promise<void>
    Przełącza tryb auto-ukrywania.

    Przykład:
      await taskbar.toggleTaskbarAutoHide();

  Całkowite ukrycie/pokazanie
  ───────────────────────────
  hideTaskbar()                                                 → Promise<void>
    Całkowicie ukrywa pasek zadań. Okna rozszerzają się na cały ekran.

    Przykład:
      await taskbar.hideTaskbar();

  showTaskbar()                                                 → Promise<void>
    Pokazuje pasek zadań po ukryciu. Okna zwalniają dla niego miejsce.

    Przykład:
      await taskbar.showTaskbar();

  Metody wewnętrzne
  ─────────────────
  _syncCSSVars()                                                → Promise<void>
    Przelicza i ustawia zmienne CSS --tb-top/bottom/left/right.

  _resizeAllWindows()                                           → Promise<void>
    Przelicza rozmiar wszystkich zmaksymalizowanych okien.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  class DesktopIconsManager
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Zarządza ikonami na pulpicie. Ikony są przeciągalne (mysz i dotyk).
  Obsługuje menu kontekstowe (prawy klik / długie naciśnięcie).

  Konstruktor
  ───────────
  new DesktopIconsManager({ containerId? })
    containerId – id kontenera pulpitu DOM (domyślnie: 'desktopIcons').

  Publiczne API
  ─────────────
  addIcon(iconObj)                                              → Promise<this>
    Dodaje ikonę lub tablicę ikon na pulpit.
    iconObj – { id, icon, label, position?, onClick?, menuItems?, disabled? }
    Jeśli ikona o danym id już istnieje, jest najpierw usuwana.

    Przykład:
      await desktop.addIcon({ id: 'di-editor', icon: '��', label: 'Edytor',
          onClick: () => view.restoreWindow({ id: 'win-editor' }) });

      await desktop.addIcon({
          id: 'di-folder', icon: '📁', label: 'Moje pliki',
          menuItems: [
              { icon: '📄', label: 'Dokument.txt', onClick: () => alert('Plik') },
              'separator',
              { icon: '📂', label: 'Otwórz folder', onClick: () => alert('Folder') }
          ]
      });

  removeIcon({ id })                                            → Promise<this>
    Przykład:
      await desktop.removeIcon({ id: 'di-editor' });

  updateIcon(iconObj)                                           → Promise<this>
    Aktualizuje właściwości istniejącej ikony. Tylko podane pola są nadpisywane.

    Przykład:
      await desktop.updateIcon({ id: 'di-editor', label: 'Edytor *', icon: '📋' });

  getIconPosition({ id })                               → Promise<{x,y}|null>
    Przykład:
      const pos = await desktop.getIconPosition({ id: 'di-editor' });
      console.log(pos); // { x: 20, y: 20 }

  setIconPosition(iconObj)                                      → Promise<this>
    Przykład:
      await desktop.setIconPosition({ id: 'di-editor', position: { x: 100, y: 200 } });

  getIcons()                               → Promise<Array<{id,...cfg}>>
    Zwraca tablicę wszystkich ikon wraz z ich bieżącymi pozycjami.

    Przykład:
      const icons = await desktop.getIcons();
      // [ { id: 'di-editor', icon: '📝', label: 'Edytor', position: { x: 20, y: 20 } } ]

  Wewnętrzne metody
  ─────────────────
  _nextGridPos()                                       → Promise<{x,y}>
  _createEl(id, cfg, pos)                              → Promise<HTMLElement>
  _selectIcon(id)                                               → Promise<void>
  _openMenu(e, id, cfg, items)                                  → Promise<void>
  _closeMenu()                                                  → Promise<void>
  _makeDraggable(el, id)                                        → Promise<void>
  _savePos(id, el)                                              → Promise<void>

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  INICJALIZACJA (bottom of app.js)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  const view     = new WindowManager({ containerId: 'windowContainer', taskbarId: 'taskbar' });
  const taskbar  = new TaskbarManager({ taskbarId: 'taskbar' });
  const desktopIcons = new DesktopIconsManager({ containerId: 'desktopIcons' });

  await taskbar.refreshTaskbar({ showStart: true, items: [] });
  await taskbar.setTaskbarPosition('bottom');

  Metody DesktopIconsManager są kopiowane (bind) na obiekt `view`:
    view.addIcon(...), view.removeIcon(...) itp.

  Metody TaskbarManager są kopiowane (bind) na obiekt `view`:
    view.refreshTaskbar(...), view.setTaskbarPosition(...) itp.

  Metody WindowManager pozostają na instancji view:
    view.addWindow(...), view.removeWindow(...) itp.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  PRZYKŁADY UŻYCIA
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  ── Typowy workflow: okno + menu + treść + pasek + ikona pulpitu ─────────────

  // 1. Utwórz okno
  await view.addWindow({ id: 'win-editor', title: 'Edytor', icon: '📝',
      statusText: 'Nowy dokument', size: { width: 800, height: 500 } });

  // 2. Dodaj menu
  await view.refreshWindowMenubar({ id: 'win-editor', menus: [
      { label: 'Plik', id: 'menu-file', items: [
          { icon: '📄', label: 'Nowy',   onClick: () => {} },
          { icon: '💾', label: 'Zapisz', onClick: () =>
              view.setWindowStatus({ id: 'win-editor', text: 'Zapisano' }) }
      ]},
      { label: 'Widok', id: 'menu-view', items: [
          { icon: '🔍', label: 'Powiększ', onClick: () => {} }
      ]}
  ]});

  // 3. Dodaj treść
  await view.refreshWindowContent({ id: 'win-editor',
      header: 'Edytor tekstu', subheader: 'Wersja 1.0',
      cards: [
          { id: 'card-main', title: '📄 Dokument', text: '<p>Witaj!</p>' }
      ]
  });

  // 4. Dodaj do paska zadań
  await taskbar.addTaskbarItem({
      id: 'tb-editor', icon: '📝', title: 'Edytor',
      onClick: () => view.restoreWindow({ id: 'win-editor' }),
      menuItems: [
          { label: 'Przywróć',    onClick: () => view.restoreWindow({ id: 'win-editor' }) },
          { label: 'Minimalizuj', onClick: () => view.minimizeWindow({ id: 'win-editor' }) },
          { label: 'Maksymalizuj',onClick: () => view.maximizeWindow({ id: 'win-editor' }) },
          'separator',
          { label: 'Zamknij', onClick: () => {
              view.removeWindow({ id: 'win-editor' });
              taskbar.removeTaskbarItem({ id: 'tb-editor' });
          }}
      ]
  });

  // 5. Dodaj ikonę pulpitu
  await desktop.addIcon({ id: 'di-editor', icon: '📝', label: 'Edytor',
      onClick: () => view.restoreWindow({ id: 'win-editor' }) });

  ── Różne warianty tworzenia okien ──────────────────────────────────────────

  // Okno z automatycznym rozmiarem:
  await view.addWindow({ id: 'win-1', title: 'Notatnik', icon: '📝' });

  // Okno z rozmiarem w pikselach:
  await view.addWindow({ id: 'win-2', title: 'Kalkulator', size: { width: 400, height: 300 } });

  // Okno z rozmiarem CSS:
  await view.addWindow({ id: 'win-3', title: 'Przeglądarka', size: { width: '80%', height: '70%' } });

  // Modal bez przycisku zamknięcia:
  await view.addWindow({ id: 'win-4', title: 'Modal', controls: { close: false } });

  // Alert – tylko przycisk zamknięcia:
  await view.addWindow({ id: 'win-5', title: 'Alert', controls: { minimize: false, maximize: false } });

  // Splash – bez żadnych przycisków:
  await view.addWindow({ id: 'win-6', title: 'Splash',
      controls: { minimize: false, maximize: false, close: false } });

  ── Dynamiczne modyfikacje okna ─────────────────────────────────────────────

  await view.setWindowTitle({ id: 'win-1', title: 'Notatnik – plik.txt' });
  await view.setWindowStatus({ id: 'win-1', text: 'Plik zapisany' });
  await view.setWindowHeader({ id: 'win-1', text: 'Mój dokument' });
  await view.setWindowSubheader({ id: 'win-1', text: 'Ostatnio: 12:00' });

  await view.addWindowCard({ id: 'win-1', cardId: 'c1', title: 'Sekcja', text: 'Treść.' });
  await view.updateWindowCard({ id: 'win-1', cardId: 'c1', text: 'Nowa treść.' });
  await view.removeWindowCard({ id: 'win-1', cardId: 'c1' });

  await view.addWindowButton({ id: 'win-1', btnId: 'btn-pin', label: '📌',
      onClick: () => alert('Przypięto!') });
  await view.removeWindowButton({ id: 'win-1', btnId: 'btn-pin' });

  await view.addWindowMenu({ id: 'win-1', menuId: 'menu-tools', label: 'Narzędzia',
      items: [{ icon: '🔧', label: 'Opcje', onClick: () => {} }] });
  await view.addWindowMenuItem({ id: 'win-1', menuId: 'menu-tools',
      item: { icon: '📊', label: 'Statystyki', onClick: () => {} } });
  await view.removeWindowMenuItem({ id: 'win-1', menuId: 'menu-tools', itemId: 'mi-stat' });
  await view.removeWindowMenu({ id: 'win-1', menuId: 'menu-tools' });

  await view.addMeniuWindow({ id: 'win-1', menuId: 'menu-edit', label: 'Edycja',
      items: [{ icon: '✏️', label: 'Edytuj', onClick: () => {} }] });
  await view.refreshMeniuWindow({ id: 'win-1', menuId: 'menu-edit',
      items: [{ icon: '✂️', label: 'Wytnij', onClick: () => {} }] });
  await view.deleteMeniuWindow({ id: 'win-1', menuId: 'menu-edit' });

  await view.minimizeWindow({ id: 'win-1' });
  await view.maximizeWindow({ id: 'win-1' });
  await view.restoreWindow({ id: 'win-1' });
  const zmin = await view.isWindowMinimized({ id: 'win-1' });
  const zmax = await view.isWindowMaximized({ id: 'win-1' });
  await view.removeWindow({ id: 'win-1' });

  ── Pasek zadań ─────────────────────────────────────────────────────────────

  await taskbar.setTaskbarPosition('top');
  await taskbar.setTaskbarPosition('left');
  await taskbar.setTaskbarPosition('bottom');

  await taskbar.setTaskbarAutoHide(true);
  await taskbar.setTaskbarAutoHide(false);
  await taskbar.toggleTaskbarAutoHide();

  await taskbar.hideTaskbar();
  await taskbar.showTaskbar();

  await taskbar.refreshStartMenu({ items: [
      { id: 'sm-editor', icon: '📝', label: 'Edytor',
        onClick: () => view.restoreWindow({ id: 'win-editor' }) },
      'separator',
      { id: 'sm-off', icon: '⏻', label: 'Wyłącz', disabled: true }
  ]});

  ── Ikony pulpitu ────────────────────────────────────────────────────────────

  await desktop.addIcon({ id: 'di-1', icon: '📝', label: 'Notatnik',
      onClick: () => view.restoreWindow({ id: 'win-1' }) });

  await desktop.addIcon({
      id: 'di-folder', icon: '📁', label: 'Moje pliki',
      menuItems: [
          { icon: '📄', label: 'Dokument.txt',  onClick: () => alert('Plik') },
          'separator',
          { icon: '📂', label: 'Otwórz folder', onClick: () => alert('Folder') }
      ]
  });

  await desktop.updateIcon({ id: 'di-1', label: 'Notatnik *' });
  await desktop.setIconPosition({ id: 'di-1', position: { x: 100, y: 200 } });
  const pos = await desktop.getIconPosition({ id: 'di-1' });
  const icons = await desktop.getIcons();
  await desktop.removeIcon({ id: 'di-1' });

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  class ContextMenuManager
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  Globalny menedżer menu kontekstowych. Pozwala dołączyć menu (prawy klik /
  długie naciśnięcie) do dowolnego elementu DOM lub grupy elementów CSS.
  Menu automatycznie koryguje pozycję, aby nie wychodziło poza ekran.

  Eksport: import view, { contextMenu } from './app.js';

  Publiczne metody
  ────────────────
  attachTo({ element, items })                              → Promise<this>
  attachToSelector({ selector, items, container? })         → Promise<this>
  detachFrom({ element })                                   → Promise<this>
  open({ x, y, items })                                     → Promise<this>
  close()                                                   → Promise<this>

  Format pozycji menu (item)
  ──────────────────────────
  { icon?, label, disabled?, onClick? }  lub  'separator'

  Przykłady
  ─────────
  import view, { contextMenu } from './app.js';

  // 1. Menu na konkretnym elemencie:
  const el = document.getElementById('moj-element');
  await contextMenu.attachTo({
      element: el,
      items: [
          { icon: '✏️', label: 'Edytuj', onClick: async () => {} },
          { icon: '📋', label: 'Kopiuj', onClick: async () => {} },
          'separator',
          { icon: '🗑️', label: 'Usuń',   onClick: async () => {} },
          { label: 'Wyłączona', disabled: true }
      ]
  });

  // 2. Menu na grupie elementów:
  await contextMenu.attachToSelector({
      selector: '.lista-item',
      items: [
          { icon: '🔍', label: 'Szczegóły', onClick: async ev => console.log(ev) },
          { icon: '⭐', label: 'Ulubione',  onClick: async ev => console.log(ev) }
      ]
  });

  // 3. Ograniczenie selektora do kontenera:
  await contextMenu.attachToSelector({
      selector: 'button.akcja',
      items: [{ label: 'Akcja', onClick: async () => alert('OK') }],
      container: document.getElementById('moj-kontener')
  });

  // 4. Otwieranie menu ręcznie:
  document.getElementById('btn-menu').addEventListener('click', async e => {
      const r = e.target.getBoundingClientRect();
      await contextMenu.open({
          x: r.left, y: r.bottom + 4,
          items: [
              { label: 'Opcja A', onClick: async () => {} },
              'separator',
              { label: 'Opcja B', onClick: async () => {} }
          ]
      });
  });

  // 5. Odłącz i zamknij:
  await contextMenu.detachFrom({ element: el });
  await contextMenu.close();

  // 6. Menu wbudowane w ikonę pulpitu (użyj menuItems w addIcon):
  await desktop.addIcon({
      id: 'di-folder', icon: '📁', label: 'Moje pliki',
      menuItems: [
          { icon: '📄', label: 'Dokument.txt',  onClick: async () => alert('Plik') },
          { icon: '📂', label: 'Otwórz folder', onClick: async () => alert('Folder') }
      ]
  });

  // 7. Dynamiczne elementy DOM:
  const newRow = document.createElement('div');
  newRow.className = 'lista-item';
  document.getElementById('lista').appendChild(newRow);
  await contextMenu.attachTo({
      element: newRow,
      items: [{ label: 'Usuń wiersz', onClick: async () => newRow.remove() }]
  });
