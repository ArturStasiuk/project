{
    "name": "arturstasiuk/myappproject",
    "description": "Backend API for myAppProject – PHP 8.x, PSR-4 autoloading, PDO, session management.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
